# ──────────────────────────────────────────────────────────────────────────
# CodeForge AI — environment variables
# Copy to .env.local and fill in. Only MONGODB_URI + AUTH_SECRET are
# strictly required to boot; everything else degrades gracefully.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — MongoDB (free tier: https://www.mongodb.com/cloud/atlas)
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/codeforge"

# REQUIRED — NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me"
# Set to your deployed URL in production (e.g. https://codeforgeai.io)
NEXTAUTH_URL="http://localhost:3000"

# Public site URL used for SEO canonical, sitemap, robots & social cards.
# In production set this to your domain; falls back to NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="https://codeforgeai.io"

# Emails that are auto-promoted to admin on registration (comma-separated)
ADMIN_EMAILS="you@example.com"

# AI features — Groq (free key: https://console.groq.com)
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# Code execution. Default is paiza.io (free, no key, all 12 languages).
# EXECUTION_PROVIDER="paiza"             # or "judge0" / "piston"
# PAIZA_API_KEY="guest"
# To use Judge0 CE via RapidAPI instead (https://rapidapi.com/judge0-official/api/judge0-ce):
# EXECUTION_PROVIDER="judge0"
# JUDGE0_URL="https://judge0-ce.p.rapidapi.com"
# JUDGE0_API_KEY=""
# To use a SELF-HOSTED Piston instance (the public one is whitelist-only since Feb 2026):
# EXECUTION_PROVIDER="piston"
# PISTON_URL="http://your-piston-host:2000/api/v2"

# Caching + rate limiting — Upstash Redis (free tier: https://upstash.com)
# Falls back to in-memory when unset (fine for local development).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OAuth (optional — buttons appear automatically when configured)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Feedback inbox (optional) — where the /feedback form sends submissions.
# Falls back to SMTP_USER, then info@setups.works. Requires SMTP_* configured.
FEEDBACK_EMAIL="info@setups.works"

# Analytics (optional). In production the GA4 ID defaults to G-3QG2R8NKRC;
# override here or in Admin → Settings. Dev sends no analytics unless set.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_CLARITY_ID=""

# LangSmith tracing (optional) — observability for the Groq AI calls.
# Set TRACING=true + an API key to send traces; otherwise it's a no-op.
LANGSMITH_TRACING="false"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="codeforgeai"

# ── Razorpay (subscriptions + card-on-file free trial) ─────────────────────
# Use rzp_test_* keys in dev, rzp_live_* in prod. Get them from
# Razorpay Dashboard → Settings → API Keys.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# REQUIRED for renewals and the post-trial auto-charge to be applied.
# Razorpay Dashboard → Settings → Webhooks → add a webhook:
#   URL:    https://<your-domain>/api/subscription/webhook
#   Events: subscription.charged, subscription.activated, subscription.authenticated,
#           subscription.halted, subscription.cancelled, subscription.completed, payment.failed
#   Secret: paste the same value here. Without it, every webhook is rejected and
#           plans never activate/renew from Razorpay's side.
RAZORPAY_WEBHOOK_SECRET=""

# ── reCAPTCHA v3 (bot protection on register/feedback forms) ───────────────
# Create keys at https://www.google.com/recaptcha/admin (reCAPTCHA v3).
# The SITE key is public (shipped to the browser); the SECRET must stay server-side.
# Leave both blank to disable reCAPTCHA (verification is skipped gracefully).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# ── Supabase (MongoDB → Postgres migration — in progress, see MIGRATION.md) ──
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_URL=""

# Supabase migration flag (default: mongo). Flip a module once its data is
# backfilled: DATA_BACKEND_FEEDBACK=supabase (one) or DATA_BACKEND=supabase (all).
DATA_BACKEND=""
